# This is a simple Makefile to demonstrate compile and clean targets.
# It assumes a simple C project with a main.c file and an output executable named 'my_program'.

CC = gcc
CFLAGS = -Wall -g
TARGET = my_program
SOURCES = main.c
OBJECTS = $(SOURCES:.c=.o)

# The 'all' target is the default goal.
all: $(TARGET)

# Link the object files to create the target executable.
$(TARGET): $(OBJECTS)
	$(CC) $(OBJECTS) -o $(TARGET)

# Compile source files into object files.
%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

# The 'clean' target removes generated files.
clean:
	rm -f $(OBJECTS) $(TARGET)

# The 'run' target executes the compiled program.
run: $(TARGET)
	./$(TARGET)

.PHONY: all clean run